generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  email String @unique
  password String
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trees Tree[]
}

model Tree {
  id String @id @default(uuid())
  name String
  ownerId String
  owner User @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  persons Person[]
  relationships Relationship[]
}

model Person {
  id String @id @default(uuid())
  firstName String
  lastName String
  birthDate DateTime?
  deathDate DateTime?
  bio String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  treeId String
  tree Tree @relation(fields: [treeId], references: [id])

  relationshipsA Relationship[] @relation("A")
  relationshipsB Relationship[] @relation("B")

}

model Relationship {
  id String @id @default(uuid())

  treeId String
  tree Tree @relation(fields: [treeId], references: [id])

  personAId String
  personBId String
  
  personA Person @relation("A", fields: [personAId], references: [id])
  personB Person @relation("B", fields: [personBId], references: [id])

  type RelationshipType

  @@unique([personAId, personBId, type])
}

enum RelationshipType {
  PARENT
  SPOUSE
}

